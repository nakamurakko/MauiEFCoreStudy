<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entities="clr-namespace:MauiEFCoreStudy.DB.Entities"
             xmlns:viewModels="clr-namespace:MauiEFCoreStudy.ViewModels"
             x:Class="MauiEFCoreStudy.Views.AuthorPage"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <viewModels:AuthorPageViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout>
        <Grid ColumnDefinitions="auto, *"
              RowDefinitions="auto">
            <Label Grid.Column="0"
                   Grid.Row="0"
                   Text="著者名"
                   VerticalOptions="Center" />
            <Entry Grid.Column="1"
                   Grid.Row="0"
                   Text="{Binding Author.AuthorName}" />
        </Grid>

        <Button Command="{Binding AddAuthorCommand}"
                HorizontalOptions="Center"
                Text="追加" />
    </VerticalStackLayout>

</ContentPage>
